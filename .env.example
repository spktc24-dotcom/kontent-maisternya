# Скопіюй цей файл у .env і заповни своїми значеннями.
# .env НІКОЛИ не публікуй у GitHub (він вже доданий у .gitignore).

# Токен бота від @BotFather у Telegram (не обов'язково — без нього запуститься тільки сайт)
BOT_TOKEN=твій_токен_від_botfather

# Ключ з console.anthropic.com (Settings -> API Keys) — обов'язковий, і для сайту, і для бота
ANTHROPIC_API_KEY=твій_anthropic_api_ключ

# Твій особистий Telegram chat ID — сюди дублюватимуться всі генерації з сайту.
# Як отримати: напиши /start своєму боту, потім подивись у Render Logs рядок
# "Chat ID для ADMIN_CHAT_ID: <число>" — саме на початку логів після повідомлення.
ADMIN_CHAT_ID=твій_chat_id

# Порт для сайту (Render/Railway підставлять свій автоматично, локально можна лишити 3000)
PORT=3000
